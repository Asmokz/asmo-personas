# ─────────────────────────────────────────────────────────────────────────────
# ASMO Personas — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared (all bots) ────────────────────────────────────────────────────────
ASMO_OLLAMA_BASE_URL=http://host.docker.internal:11434
ASMO_OLLAMA_MODEL=mistral:7b
ASMO_LOG_LEVEL=INFO
ASMO_LOG_JSON=true

# ── FEMTO ────────────────────────────────────────────────────────────────────
# Discord bot token (create at https://discord.com/developers/applications)
FEMTO_DISCORD_TOKEN=your-femto-discord-token-here

# Channel ID where FEMTO posts daily reports (right-click channel → Copy ID)
FEMTO_REPORT_CHANNEL_ID=

# Command execution timeout in seconds
FEMTO_CMD_TIMEOUT=10

# ── ALITA ────────────────────────────────────────────────────────────────────
ALITA_DISCORD_TOKEN=your-alita-discord-token-here

# Channel ID for morning briefings
ALITA_BRIEFING_CHANNEL_ID=
ALITA_BRIEFING_HOUR=9

# OpenWeatherMap API key (https://openweathermap.org/api)
ALITA_WEATHER_API_KEY=
ALITA_WEATHER_CITY=Paris

# ── GIORGIO ──────────────────────────────────────────────────────────────────
GIORGIO_DISCORD_TOKEN=your-giorgio-discord-token-here

# Channel ID for media recommendations
GIORGIO_RECOMMENDATION_CHANNEL_ID=

# Jellyfin configuration
GIORGIO_JELLYFIN_URL=http://your-jellyfin-host:8096
GIORGIO_JELLYFIN_API_KEY=
GIORGIO_JELLYFIN_USER_ID=
